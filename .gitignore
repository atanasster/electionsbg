# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
# Staged-for-deletion build outputs from scripts/prebuild.mjs. The script
# atomically renames dist/ to dist.old-<timestamp> so the new build can start
# while a detached process deletes the old tree in the background. If that
# detached process is interrupted the orphan stays on disk until the next
# build's sweep — keep it out of git either way.
dist.old-*
*.local
*.cache

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Commerce Registry (TR) raw dump — ~540 MB zip + ~12 GB extracted JSON.
# Re-fetch with `npx tsx scripts/declarations/tr/cli.ts --bulk` (or `--incremental`).
/raw_data/tr/

# Per-MP declaration XML cache from register.cacbg.bg. Re-fetched on demand by
# `npm run data -- --declarations`. The processed JSON outputs under
# public/parliament/declarations/ are committed; this raw cache is not.
/raw_data/declarations/

# Generated election data — regenerate with `npm run prod`
# Pattern note: ignore directory *contents* (not the directory itself) so we can
# re-include specific subtrees below. A leading-anchored `/public/2*/` would block
# any later un-ignore.
/public/2*/*
/public/sections/
/public/settlements/
/public/municipalities/
/public/regions/

# Exception: hand-curated AI campaign retrospects (committed; not regenerated by `npm run prod`)
!/public/2*/parties/
/public/2*/parties/*
!/public/2*/parties/assessment/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
