# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
# Staged-for-deletion build outputs from scripts/prebuild.mjs. The script
# atomically renames dist/ to dist.old-<timestamp> so the new build can start
# while a detached process deletes the old tree in the background. If that
# detached process is interrupted the orphan stays on disk until the next
# build's sweep — keep it out of git either way.
dist.old-*
.env.*
*.cache

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Commerce Registry (TR) raw dump — ~540 MB zip + ~12 GB extracted JSON.
# Re-fetch with `npx tsx scripts/declarations/tr/cli.ts --bulk` (or `--incremental`).
/raw_data/tr/

# Per-MP declaration XML cache from register.cacbg.bg. Re-fetched on demand by
# `npm run data -- --declarations`. The processed JSON outputs under
# public/parliament/declarations/ are committed; this raw cache is not.
/raw_data/declarations/

# Cached XML downloads from register.cacbg.bg for non-MP officials (cabinet,
# agency heads, regional governors). Re-fetch with
# `npx tsx scripts/officials/index.ts`. Processed outputs under data/officials/
# are committed; this raw cache is not.
/raw_data/officials/

# Cached XLSX downloads from external publishers (AZ годишен обзор etc.).
# Re-fetched on demand by `/update-indicators`. The merged data/indicators.json
# is committed; this raw cache is not.
/raw_data/indicators/

# Cached АОП OCDS bundles from data.egov.bg (~20 MB each, ~26/year).
# Re-fetched on demand by `/update-procurement`. The normalized JSON outputs
# under data/procurement/ are committed; this raw cache is not.
/raw_data/procurement/

# Bulky derived procurement files — same convention as /data/2*/*: regenerated
# from the corpus + cross-reference, shipped to the GCS bucket directly, not
# committed. The small metadata (index.json, bundles.json, by_ns/, derived/)
# is committed so the per-NS slice + flow + top-contractor index ship with
# the repo.
/data/procurement/contracts/
/data/procurement/contractor_contracts/
/data/procurement/awarder_contracts/
/data/procurement/contractors/
/data/procurement/awarders/

# Cached budget source artifacts (egov КФП resources, minfin Excel, bulnao
# PDFs). Re-fetched on demand by `/update-budget`. The normalized JSON outputs
# under data/budget/ are committed; this raw cache is not.
/raw_data/budget/

# Cached fiscal-reserve source artifacts (minfin.bg mreport / BULETIN PDFs +
# FRA-MM-YYYY-BG.xlsx). Re-fetched on demand by
# scripts/macro/fetch_fiscal_reserve.ts. The parsed quarterly aggregate
# (fiscal-reserve.json) is committed; the raw cache + user-drop XLSX files
# are not. The README in minfin_fr_xlsx/ stays committed so future operators
# know what to drop there.
/data/_cache/minfin_mreports/
/data/_cache/minfin_fr_xlsx/*.xlsx

# Bulky regenerable budget files — same convention as procurement above. The
# small metadata (index.json, kfp.json, documents.json, classification/,
# crosswalk-overrides.json) is committed; the per-year fact / reconciliation /
# ministry shards (Phase 2+) are regenerated and shipped to the bucket only.
/data/budget/facts/
/data/budget/reconciliation/
/data/budget/ministries/

# Generated election data — regenerate with `npm run prod`
# Pattern note: ignore directory *contents* (not the directory itself) so we can
# re-include specific subtrees below. A leading-anchored `/data/2*/` would block
# any later un-ignore.
#
# Note: as of the GCS migration these live under /data/ (not /public/). The
# Vite dev server overlays /data/ at root via a custom plugin so dev fetches
# still resolve; production builds skip /data/ entirely and the SPA fetches
# from the bucket via VITE_DATA_BASE_URL.
/data/2*/*
/data/sections/
/data/settlements/
/data/municipalities/
/data/regions/

# Exception: hand-curated AI campaign retrospects (committed; not regenerated by `npm run prod`)
!/data/2*/parties/
/data/2*/parties/*
!/data/2*/parties/assessment/

# Editor directories and files
.claude/*.local.json
.claude/scheduled_tasks.lock
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
